CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 1GB 根目录空间
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# 仅输出单一镜像
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_EXT4_BLOCKSIZE=4096
CONFIG_TARGET_EXT4_JOURNAL=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_GRUB_EFI_IMAGES=y

# 极其严格地关闭所有不需要的格式（注意：前面的 # 号是必须的语法！）
# CONFIG_TARGET_ROOTFS_SQUASHFS is not set
# CONFIG_TARGET_ROOTFS_TARGZ is not set
# CONFIG_TARGET_ROOTFS_CPIOGZ is not set
# CONFIG_TARGET_ROOTFS_EXT4FS_VHDX is not set
# CONFIG_TARGET_ROOTFS_EXT4FS_VDI is not set
# CONFIG_TARGET_ROOTFS_EXT4FS_VMDK is not set
# CONFIG_TARGET_ROOTFS_EXT4FS_QCOW2 is not set
# CONFIG_GRUB_IMAGES is not set
# CONFIG_VMDK_IMAGES is not set

# ========== 基础环境与中文支持 ==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
# 强制激活全局中文编译标识
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y

# ========== 核心插件 ==========
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_docker-ce=y
CONFIG_PACKAGE_docker-compose=y

CONFIG_PACKAGE_luci-app-openclash=y

# 强制打包主题
CONFIG_PACKAGE_luci-theme-aurora=y

# ========== 依赖库补齐 ==========
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-bin=y
